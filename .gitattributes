# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Documentation
*.md text diff=markdown
*.txt text
LICENSE text

# Config files
*.json text
*.toml text
*.yml text
*.yaml text
*.xml text
*.csv text

# Shell scripts
*.sh text eol=lf diff=bash

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archive files
*.zip binary
*.gz binary
*.tar binary

# Executables
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Go files
*.go text eol=lf diff=go
go.sum -diff merge=union

# Test fixtures
*.golden text

# Environment files
.env text eol=lf

# Export ignore (excluded from archives)
.github/ export-ignore
.claude/ export-ignore
